# ==============================================
# TinyFish Autonomous QA Agent - Environment Variables
# ==============================================
# Copy this file: cp .env.example .env
# Then fill in your actual values below

# ----------------------------------------------
# 1. TinyFish API Key (REQUIRED)
#    Get from: https://www.tinyfish.ai -> Dashboard -> API Keys
#    Free credits provided for TinyFish Hackathon 2026
# ----------------------------------------------
TINYFISH_API_KEY=your_tinyfish_api_key_here

# ----------------------------------------------
# 2. Google Gemini API Key (REQUIRED - FREE)
#    Get from: https://aistudio.google.com/app/apikey
#    Free tier: 15 requests/min, 1M tokens/day - No billing needed!
#    Model used: gemini-2.0-flash (fast + free)
# ----------------------------------------------
GOOGLE_API_KEY=your_google_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# ----------------------------------------------
# 3. Database (auto-created, no setup needed)
# ----------------------------------------------
DATABASE_URL=sqlite:///./qa_results.db

# ----------------------------------------------
# 4. Slack Webhook (OPTIONAL)
#    Get from: https://api.slack.com/messaging/webhooks
#    Leave blank to disable Slack alerts
# ----------------------------------------------
SLACK_WEBHOOK_URL=
